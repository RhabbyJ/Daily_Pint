---
import HomeNextEvent from "../components/HomeNextEvent.astro";
import Icon from "../components/Icon.astro";
import Layout from "../components/Layout.astro";
import { site } from "../config/site";
---

<Layout title={site.name} description={site.description} pageClass="home-page">
  <section class="hero landing-hero" aria-label={`${site.name} welcome`}>
    <div class="hero-content hero-intro">
      <p class="eyebrow">Neighborhood bar</p>
      <h1>{site.name}</h1>
      <p class="hero-lede">
        {site.description} Check tonight's menu, see what is coming up, and request
        a table when the night calls for one.
      </p>
      <div class="actions hero-actions">
        <a class="button" href="/menu"><Icon name="menu" />View Menu</a>
        <a class="button secondary" href="/events"><Icon name="calendar" />Events</a>
        <a class="button secondary" href="/reservations"><Icon name="users" />Request a Reservation</a>
      </div>
    </div>
    <a class="scroll-cue" href="#visit-flow" aria-label="Explore the bar">
      <span></span>
    </a>
  </section>

  <section class="home-strip" aria-label="Daily Pint highlights">
    <div>
      <span>Fresh drafts</span>
      <span>Classic cocktails</span>
      <span>Public events</span>
    </div>
  </section>

  <section id="visit-flow" class="home-section visit-flow-section">
    <div class="home-section-heading reveal">
      <h2>Start with what you need tonight.</h2>
      <p>
        Menu, events, reservations, and directions stay easy to reach without
        crowding the page.
      </p>
    </div>
    <div class="pathway-grid">
      <a class="pathway-card reveal" href="/menu">
        <span class="pathway-icon"><Icon name="menu" /></span>
        <span class="pathway-copy">
          <h3>Menu</h3>
          <p>Current pours, cocktails, plates, prices, and notes.</p>
        </span>
        <Icon name="arrow-right" class="pathway-arrow" />
      </a>
      <a class="pathway-card reveal" href="/events">
        <span class="pathway-icon"><Icon name="calendar" /></span>
        <span class="pathway-copy">
          <h3>Events</h3>
          <p>The next night out, then the full calendar view.</p>
        </span>
        <Icon name="arrow-right" class="pathway-arrow" />
      </a>
      <a class="pathway-card reveal" href="/reservations">
        <span class="pathway-icon"><Icon name="users" /></span>
        <span class="pathway-copy">
          <h3>Reservations</h3>
          <p>Send a request. Staff will confirm the details.</p>
        </span>
        <Icon name="arrow-right" class="pathway-arrow" />
      </a>
      <a class="pathway-card reveal" href="/contact">
        <span class="pathway-icon"><Icon name="map-pin" /></span>
        <span class="pathway-copy">
          <h3>Contact</h3>
          <p>Call, follow, or get directions without digging.</p>
        </span>
        <Icon name="arrow-right" class="pathway-arrow" />
      </a>
    </div>
  </section>

  <section class="home-section menu-showcase-section">
    <div class="showcase-panel reveal">
      <h2>The current board, kept fresh.</h2>
      <p>
        Guests see the items that are available now, organized by section with
        simple prices, descriptions, and helpful tags.
      </p>
      <div class="mini-list" aria-label="Menu capabilities">
        <p><Icon name="check" /><span>Unavailable items stay off the public menu.</span></p>
        <p><Icon name="check" /><span>Sections follow the order guests expect.</span></p>
        <p><Icon name="check" /><span>Tags keep quick choices clear.</span></p>
      </div>
      <a class="text-link" href="/menu">Explore the current menu <Icon name="arrow-right" /></a>
    </div>
    <div class="bar-snapshot reveal" aria-hidden="true">
      <div>
        <span>Drafts</span>
        <strong>House Lager</strong>
        <small>Crisp / cold / reliable</small>
      </div>
      <div>
        <span>Cocktails</span>
        <strong>Gold Rush</strong>
        <small>Bourbon / lemon / honey</small>
      </div>
      <div>
        <span>Seasonal</span>
        <strong>Rotating Tap</strong>
        <small>Updated by staff</small>
      </div>
    </div>
  </section>

  <section class="home-section events-showcase-section">
    <div class="showcase-panel reveal">
      <h2>A simple look at what is coming up.</h2>
      <p>
        The homepage shows the next public event first. Guests who want to plan
        ahead can open the full calendar and complete event list.
      </p>
      <a class="button" href="/events"><Icon name="calendar" />View Calendar and More Events</a>
    </div>
    <div class="reveal">
      <HomeNextEvent />
    </div>
  </section>

  <section class="reservation-cta reveal">
    <h2>Bring the group. Staff will confirm the details.</h2>
    <p>
      Send the date, time, and party size. The request is received by staff, then
      confirmed directly with the guest.
    </p>
    <a class="button" href="/reservations"><Icon name="users" />Request a Reservation</a>
  </section>

  <script is:inline>
    document.documentElement.classList.add("js-enabled");

    const revealItems = document.querySelectorAll(".reveal");
    const revealObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.08, rootMargin: "0px 0px 12% 0px" },
    );

    for (const item of revealItems) {
      revealObserver.observe(item);
    }
  </script>
</Layout>
