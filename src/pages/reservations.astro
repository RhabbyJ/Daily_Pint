---
import Layout from "../components/Layout.astro";
import { site } from "../config/site";

const tallySrc = site.tallyFormId
  ? `https://tally.so/embed/${site.tallyFormId}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`
  : "";
---

<Layout title={`Reservations | ${site.name}`} description={`Request a reservation at ${site.name}.`}>
  <section class="page-heading">
    <p class="eyebrow">Staff-confirmed</p>
    <h1>Request a Reservation</h1>
    <p>Reservations are not confirmed until our staff contacts you.</p>
  </section>

  <section class="reservation-form">
    {
      tallySrc ? (
        <>
          <iframe
            data-tally-src={tallySrc}
            loading="lazy"
            width="100%"
            height="650"
            title="Request a Reservation"
          />
          <script is:inline async src="https://tally.so/widgets/embed.js" />
        </>
      ) : (
        <div class="empty-state">
          <h2>Reservation form is not configured yet.</h2>
          <p>Add the Tally form ID to <code>PUBLIC_TALLY_FORM_ID</code> to enable requests.</p>
        </div>
      )
    }
  </section>
</Layout>
