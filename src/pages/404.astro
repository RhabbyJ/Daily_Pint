---
import Icon from "../components/Icon.astro";
import Layout from "../components/Layout.astro";
import { site } from "../config/site";
---

<Layout title={`Page Not Found | ${site.name}`} description="Page not found.">
  <section class="page-heading page-heading-grid">
    <div>
      <p class="eyebrow">404</p>
      <h1>Page Not Found</h1>
      <p>The page you are looking for does not exist. These links will get you back to the bar.</p>
    </div>
    <div class="page-action-panel" aria-label="Helpful links">
      <a href="/"><Icon name="home" />Home</a>
      <a href="/menu"><Icon name="menu" />Menu</a>
      <a href="/events"><Icon name="calendar" />Events</a>
      <a href="/reservations"><Icon name="users" />Request a Reservation</a>
    </div>
  </section>
</Layout>
