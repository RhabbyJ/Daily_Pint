---
interface Props {
  name:
    | "arrow-right"
    | "beer"
    | "calendar"
    | "check"
    | "clock"
    | "compass"
    | "home"
    | "instagram"
    | "list"
    | "map-pin"
    | "menu"
    | "phone"
    | "sparkles"
    | "users";
