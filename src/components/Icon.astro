};
---

<svg
  class:list={["icon", className]}
  aria-hidden={label ? undefined : "true"}
  role={label ? "img" : undefined}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  {label && <title>{label}</title>}
  <Fragment set:html={paths[name]} />
</svg>
